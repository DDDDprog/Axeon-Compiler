// ZeoC - Modern C-like Syntax
import std.io

fn main() -> int {
    // Variables
    let x: int = 10
    let y: int = 20
    let sum: int = 0
    
    // For loop (C-style)
    for (int i = 0; i < 5; i = i + 1) {
        sum = sum + i
    }
    print(sum)
    
    // While loop
    let count: int = 0
    while (count < 3) {
        count = count + 1
    }
    print(count)
    
    // If-else
    if (x > y) {
        print(x)
    } else {
        print(y)
    }
    
    // Switch
    let z: int = 2
    switch (z) {
        case 1: print(100)
        case 2: print(200)
        default: print(0)
    }
    
    // Types
    let a: u32 = 50
    let b: i64 = -25
    let flag: bool = true
    
    // Pointer
    let p: *int = &x
    
    // Array (as pointer)
    let arr: [int] = &x
    
    // Break/Continue
    for (int i = 0; i < 10; i = i + 1) {
        if (i == 5) {
            break
        }
    }
    
    return 0
}
