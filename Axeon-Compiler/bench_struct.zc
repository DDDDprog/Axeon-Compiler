import std.io

struct Point {
    x: int,
    y: int
}

fn distance(p1: Point, p2: Point) -> int {
    let dx: int = p2.x - p1.x
    let dy: int = p2.y - p1.y
    return dx * dx + dy * dy
}

fn main() -> int {
    let p1: Point = Point { x: 0, y: 0 }
    let p2: Point = Point { x: 3, y: 4 }
    let d: int = distance(p1, p2)
    print(d)
    return 0
}
